# Copy to .env and fill in values before running docker compose up
# NEVER commit .env — only .env.example is tracked in git

# ── Secrets (required) ──────────────────────────────────────
JWT_SECRET=replace-with-random-secret
POSTGRES_PASSWORD=replace-with-random-password
REDIS_PASSWORD=replace-with-random-password
RABBITMQ_PASSWORD=replace-with-random-password

# ── Optional overrides ──────────────────────────────────────
POSTGRES_USER=sga
RABBITMQ_USER=sga
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507
