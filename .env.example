# Copy to .env and fill in real values — never commit .env

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=sga
POSTGRES_PASSWORD=sga_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
USER_DB_URL=postgres://sga:sga_secret@localhost:5432/user_db?sslmode=disable
LIST_DB_URL=postgres://sga:sga_secret@localhost:5432/list_db?sslmode=disable

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=sga
RABBITMQ_PASSWORD=sga_secret
RABBITMQ_URL=amqp://sga:sga_secret@localhost:5672/

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ── Services ────────────────────────────────────────────────
API_GATEWAY_PORT=3000
USER_SERVICE_URL=http://localhost:4001
LIST_SERVICE_URL=http://localhost:4002
AI_SERVICE_URL=http://localhost:4003

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
