{
  "vhosts": [{ "name": "/" }],
  "queues": [
    {
      "name": "ai.jobs",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": { "x-message-ttl": 300000 }
    },
    {
      "name": "ai.results",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": { "x-message-ttl": 300000 }
    },
    {
      "name": "list.events",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "ai",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "list",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false
    }
  ],
  "bindings": [
    { "source": "ai",   "vhost": "/", "destination": "ai.jobs",    "destination_type": "queue", "routing_key": "jobs" },
    { "source": "ai",   "vhost": "/", "destination": "ai.results",  "destination_type": "queue", "routing_key": "results" },
    { "source": "list", "vhost": "/", "destination": "list.events", "destination_type": "queue", "routing_key": "" }
  ]
}
