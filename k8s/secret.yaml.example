# Copy this file to secret.yaml and fill in real values:
#   cp k8s/secret.yaml.example k8s/secret.yaml
#
# secret.yaml is gitignored — never commit real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: sga-secret
  namespace: sga
stringData:
  postgres-password: sga_secret
  redis-password: redis_secret
  rabbitmq-password: sga_secret
  jwt-secret: change_me_in_production
  openrouter-api-key: sk-or-...your-key-here...
  openrouter-model: anthropic/claude-opus-4.6
